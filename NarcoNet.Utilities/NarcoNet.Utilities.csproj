<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net472;net9.0</TargetFrameworks>
        <AppendTargetFrameworkToOutputPath>true</AppendTargetFrameworkToOutputPath>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>

        <!-- Enable deployment after build -->
        <DeployAfterBuild>true</DeployAfterBuild>
    </PropertyGroup>

    <!-- Generate version constant at compile time -->
    <Target Name="GenerateVersionFile" BeforeTargets="BeforeCompile">
        <PropertyGroup>
            <VersionFileContent>
// Auto-generated file - DO NOT EDIT
// Version comes from git tag in CI, or VersionPrefix in Directory.Build.props for local builds

namespace NarcoNet.Utilities%3b

public static class NarcoNetVersion
{
    public const string Version = "$(VersionPrefix)"%3b
}
            </VersionFileContent>
        </PropertyGroup>
        <WriteLinesToFile File="$(IntermediateOutputPath)NarcoNetVersion.g.cs" Lines="$(VersionFileContent)" Overwrite="true" />
        <ItemGroup>
            <Compile Include="$(IntermediateOutputPath)NarcoNetVersion.g.cs" />
        </ItemGroup>
    </Target>

    <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
        <Compile Remove="ColorExtensions.cs"/>
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net472'">
        <Reference Include="UnityEngine">
            <HintPath>$(TarkovManagedDir)UnityEngine.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.CoreModule">
            <HintPath>$(TarkovManagedDir)UnityEngine.CoreModule.dll</HintPath>
        </Reference>
    </ItemGroup>

    <Target Name="PostBuild" AfterTargets="PostBuildEvent" Condition="'$(DeployAfterBuild)' == 'true' AND '$(TargetFramework)' == 'net472' AND '$(SolutionDir)' != '' AND '$(SolutionDir)' != '*Undefined*'">
        <PropertyGroup>
            <BuildOutputDir>$(SolutionDir)Build\BepInEx\plugins\MadManBeavis-NarcoNet</BuildOutputDir>
        </PropertyGroup>

        <!-- Create output directory structure -->
        <MakeDir Directories="$(BuildOutputDir)"/>

        <!-- Copy the Utilities DLL -->
        <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(BuildOutputDir)"/>

        <Message Text="NarcoNet.Utilities copied to: $(BuildOutputDir)" Importance="high"/>
    </Target>

</Project>
