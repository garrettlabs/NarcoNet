<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
        <!-- GitLab registry — added dynamically in CI via before_script.
             For local use:  dotnet nuget add source "https://gitlab.com/api/v4/projects/YOUR_PROJECT_ID/packages/nuget/index.json"
                             -\-name gitlab -\-username YOUR_USERNAME -\-password YOUR_TOKEN -\-store-password-in-clear-text  -->
    </packageSources>
</configuration>
